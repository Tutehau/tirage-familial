# Copie ce fichier en .env.local pour le développement local
# (en production sur Hostinger, ces variables se configurent dans
# hPanel → Node.js → Settings & Redeploy → Environment variables)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=votre-compte@example.com
SMTP_PASS=votre-mot-de-passe-application

# Supabase (dashboard du projet → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key
# Clé secrète, jamais exposée au navigateur — Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key
